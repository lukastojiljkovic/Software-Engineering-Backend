# SEC-02 — Banka 2 dev environment variables.
#
# Kopiraj ovaj fajl u `.env` u istom folderu (Banka-2-Backend/) i edituj
# vrednosti pre `docker compose up`. `.env` JE u .gitignore-u — ne commit-uj
# secret-e ni u dev grane.
#
# `docker compose` ucitava `.env` automatski iz radnog foldera (CWD pri
# `docker compose up`). Ako vrednost ne moze da se nadje, varijable
# oznacene `${X:?...}` u docker-compose.yml-u fail-uju startup sa jasnom
# porukom — ovo je BUDZET PRINCIP: nikad nemamo silent fall-back-ove na
# slabe lozinke u produkciji.
#
# Production: rotiraj sve vrednosti, postavi kroz CI/CD secret manager,
# *NIKAD* ne commit-uj `.env` fajl.

# ── Databases (SEC-02) ───────────────────────────────────────────────────
POSTGRES_PASSWORD=banka2pass_dev_ONLY
POSTGRES_TRADING_PASSWORD=tradingpass_dev_ONLY
# Opcioni — replicator postgres user (default je u docker-compose.yml).
POSTGRES_REPLICATION_PASSWORD=replicator_pass

# ── JWT (auth) ───────────────────────────────────────────────────────────
# HS256 secret. Produkcija MORA biti random >= 256 bita (cca 64 hex).
JWT_SECRET=dev-only-jwt-secret-do-not-use-in-prod-rotate-via-env-var-on-each-deploy

# ── Eksterni API kljucevi ────────────────────────────────────────────────
EXCHANGE_API_KEY=
# Alpha Vantage round-robin (4 kljuca, comma-separated).
STOCK_API_KEYS=

# ── Email (SMTP) ─────────────────────────────────────────────────────────
MAIL_USERNAME=banka2.notifications@gmail.com
MAIL_PASSWORD=

# ── Inter-bank protokol (Tim 1 partner banka) ────────────────────────────
# Generisi `head -c 32 /dev/urandom | xxd -p` (64-hex random) za produkciju.
INTERNAL_API_KEY=dev-internal-key
PARTNER1_INBOUND_TOKEN=dev-partner-token
PARTNER1_OUTBOUND_TOKEN=dev-outbound-token

# ── InfluxDB (opciono — observability/timeseries) ────────────────────────
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=admin12345
INFLUX_ORG=banka2
INFLUX_BUCKET=tick-listings
INFLUX_TOKEN=dev-token-change-me-32-bytes-minimum

# ── Host port overrides (opciono — za Windows Hyper-V exclusion ranges) ──
# BACKEND_HOST_PORT=8081
# GATEWAY_HOST_PORT=8080
# ADMINER_HOST_PORT=9001
# RABBITMQ_HOST_PORT=5672
# RABBITMQ_MGMT_HOST_PORT=15672
